set dotenv-load

# Run dev server
dev:
    bun run dev

# Build for production
build:
    bun run build

# Start production server
start:
    bun run start

# Run tests
test:
    bun run test

# Full test suite
tests:
    bun run tests

# Lint
lint:
    bun run lint

# Format
format:
    bun run format

# Type check
typecheck:
    bun run typecheck
